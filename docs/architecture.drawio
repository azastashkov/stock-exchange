        <mxCell id="lg1" value="Engine + log = single-writer hot path" style="rounded=1;fillColor=#D5E8D4;strokeColor=#82B366;align=center;verticalAlign=middle;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="340" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="lg2" value="Pre-trade pipeline loop (allocation-free)" style="rounded=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=center;verticalAlign=middle;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="715" width="340" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="lg3" value="Gateway / event log (binary IO with mmap)" style="rounded=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="750" width="340" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="lg4" value="Client / external endpoint" style="rounded=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="785" width="340" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="lg5" value="mmap ring buffer (SPSC, 256-byte slots)" style="rounded=0;fillColor=#FFFFFF;strokeColor=#999999;align=center;verticalAlign=middle;fontStyle=2;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="820" width="340" height="28" as="geometry"/>
