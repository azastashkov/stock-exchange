        <mxCell id="e-log-mdp" style="endArrow=classic;html=1" edge="1" parent="1" source="log" target="mdp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-log-pos" style="endArrow=classic;html=1" edge="1" parent="1" source="log" target="pos"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-rep-r" style="endArrow=classic;html=1" edge="1" parent="1" source="rep" target="r-out"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-r-gw" style="endArrow=classic;html=1" edge="1" parent="1" source="r-out" target="gw-out"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-gw-cl2" style="endArrow=classic;html=1" edge="1" parent="1" source="gw-out" target="cl2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-mdp-sub" style="endArrow=classic;html=1" edge="1" parent="1" source="mdp" target="md-sub"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ====================== Observability (right) ====================== -->
        <mxCell id="g-obs" value="Observability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F0FF;strokeColor=#7E64C1;verticalAlign=top;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1260" y="80" width="400" height="540" as="geometry"/>
        </mxCell>

        <mxCell id="actuator" value="Spring Boot Actuator&#10;/actuator/prometheus on :8080&#10;(every node, exposes Micrometer)" style="rounded=1;fillColor=#FFFFFF;strokeColor=#7E64C1;align=center;verticalAlign=middle;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1290" y="120" width="340" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="prom" value="Prometheus&#10;scrapes 5 nodes every 5s" style="rounded=1;fillColor=#FCE5CD;strokeColor=#D79B00;align=center;verticalAlign=middle;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1310" y="220" width="300" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="graf" value="Grafana&#10;auto-provisioned datasource + dashboard&#10;(latency, throughput, ring depth, Raft role,&#10;commit lag, GC pause, top-of-book, ...)" style="rounded=1;fillColor=#D5A6BD;strokeColor=#A05195;align=center;verticalAlign=middle;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1290" y="320" width="340" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="loadc" value="Java Load Client (FIX 4.4)&#10;HdrHistogram, leader redirect,&#10;rate-limited token bucket" style="rounded=1;fillColor=#F8CECC;strokeColor=#B85450;align=center;verticalAlign=middle;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1310" y="460" width="300" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="t-obs-result" value="Headline result: p99 = 3.98 ms&#10;@ 60 s of load against full Raft cluster" style="text;html=1;strokeColor=none;fillColor=#FFFFFF;align=center;verticalAlign=middle;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1290" y="555" width="340" height="50" as="geometry"/>
